{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "chatbot: sync chatbot artifacts",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "./scripts/sync-chatbot-kb.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "chatbot: rebuild + sync artifacts",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "docker compose up -d --build chatbot_service; ./scripts/sync-chatbot-kb.ps1"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    }
  ]
}