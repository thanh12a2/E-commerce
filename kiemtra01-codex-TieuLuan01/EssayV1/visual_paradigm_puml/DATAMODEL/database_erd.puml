@startuml ECommerce-Database-ERD

' ============================================================
' STYLE - Visual Paradigm-like ERD
' ============================================================
skinparam backgroundColor white
skinparam shadowing false
skinparam linetype ortho
skinparam entity {
  BackgroundColor #F6B26B
  BorderColor #6B3F13
  FontColor #111111
  HeaderBackgroundColor #E69138
  HeaderFontColor #111111
}
skinparam ArrowColor #6B3F13
skinparam ArrowFontColor #111111
skinparam ArrowFontSize 9
hide circle

title Database ERD - E-Commerce Microservices System

' ============================================================
' user_db - MySQL
' ============================================================
entity "auth_user" as auth_user {
  * id : int <<PK>>
  --
  username : varchar(150) <<UK>>
  first_name : varchar(150)
  last_name : varchar(150)
  email : varchar(254)
  password : varchar(128)
  is_staff : bool
  is_superuser : bool
  is_active : bool
  date_joined : datetime
  last_login : datetime
}

entity "customer_blogpost" as customer_blogpost {
  * id : bigint <<PK>>
  --
  title : varchar(220)
  slug : varchar(50) <<UK>>
  category : varchar(80)
  author : varchar(120)
  excerpt : text
  body : text
  hero_image_url : varchar(200)
  published_at : date
  created_at : datetime
}

entity "customer_testimonial" as customer_testimonial {
  * id : bigint <<PK>>
  --
  name : varchar(120)
  role : varchar(120)
  rating : smallint
  quote : text
  avatar_url : varchar(200)
  is_featured : bool
  created_at : datetime
}

entity "customer_legacyusermapping" as customer_legacyusermapping {
  * id : bigint <<PK>>
  --
  user_id : int <<FK auth_user.id>>
  legacy_source : varchar(20)
  legacy_user_id : int
  legacy_username : varchar(150)
  legacy_email : varchar(254)
  note : text
  created_at : datetime
  UNIQUE(legacy_source, legacy_user_id)
}

' ============================================================
' product_db - PostgreSQL
' ============================================================
entity "catalog_category" as catalog_category {
  * id : bigint <<PK>>
  --
  name : varchar(120) <<UK>>
  slug : varchar(120) <<UK>>
  description : text
  hero_image_url : varchar(200)
  sort_order : int
  is_active : bool
}

entity "catalog_product" as catalog_product {
  * id : bigint <<PK>>
  --
  category_id : bigint <<FK catalog_category.id>>
  name : varchar(255)
  brand : varchar(120)
  description : text
  image_url : varchar(200)
  price : decimal(12,2)
  stock : int
  created_at : datetime
  updated_at : datetime
  UNIQUE(category_id, name, brand)
}

' ============================================================
' order_db - MySQL
' ============================================================
entity "orders_cartitem" as orders_cartitem {
  * id : bigint <<PK>>
  --
  user_id : int <<IDX>>
  category_slug : varchar(120)
  category_name : varchar(120)
  product_id : int
  product_name : varchar(255)
  product_brand : varchar(120)
  product_image_url : varchar(200)
  unit_price : decimal(12,2)
  quantity : int
  created_at : datetime
  updated_at : datetime
  UNIQUE(user_id, category_slug, product_id)
}

entity "orders_saveditem" as orders_saveditem {
  * id : bigint <<PK>>
  --
  user_id : int <<IDX>>
  category_slug : varchar(120)
  category_name : varchar(120)
  product_id : int
  product_name : varchar(255)
  product_brand : varchar(120)
  product_image_url : varchar(200)
  unit_price : decimal(12,2)
  created_at : datetime
  UNIQUE(user_id, category_slug, product_id)
}

entity "orders_compareitem" as orders_compareitem {
  * id : bigint <<PK>>
  --
  user_id : int <<IDX>>
  category_slug : varchar(120)
  category_name : varchar(120)
  product_id : int
  product_name : varchar(255)
  product_brand : varchar(120)
  product_image_url : varchar(200)
  unit_price : decimal(12,2)
  stock : int
  created_at : datetime
  UNIQUE(user_id, category_slug, product_id)
}

entity "orders_order" as orders_order {
  * id : bigint <<PK>>
  --
  user_id : int <<IDX>>
  total_amount : decimal(12,2)
  payment_status : varchar(20)
  shipping_status : varchar(20)
  source : varchar(20)
  source_order_id : int <<IDX>>
  paid_at : datetime
  created_at : datetime
  updated_at : datetime
  UNIQUE(source, source_order_id)
}

entity "orders_orderitem" as orders_orderitem {
  * id : bigint <<PK>>
  --
  order_id : bigint <<FK orders_order.id>>
  category_slug : varchar(120)
  category_name : varchar(120)
  product_id : int
  product_name : varchar(255)
  product_brand : varchar(120)
  product_image_url : varchar(200)
  unit_price : decimal(12,2)
  quantity : int
}

entity "orders_ordershipping" as orders_ordershipping {
  * id : bigint <<PK>>
  --
  order_id : bigint <<FK orders_order.id, UK>>
  recipient_name : varchar(120)
  phone : varchar(40)
  address_line : varchar(255)
  city_or_region : varchar(120)
  postal_code : varchar(40)
  country : varchar(120)
  note : text
}

' ============================================================
' payment_db - PostgreSQL
' ============================================================
entity "payments_payment" as payments_payment {
  * id : bigint <<PK>>
  --
  order_id : int <<UK>>
  user_id : int <<IDX>>
  amount : decimal(12,2)
  status : varchar(20)
  paid_at : datetime
  created_at : datetime
  updated_at : datetime
  INDEX(user_id, status)
}

' ============================================================
' shipping_db - PostgreSQL
' ============================================================
entity "shipments_shipment" as shipments_shipment {
  * id : bigint <<PK>>
  --
  order_id : int <<UK>>
  user_id : int <<IDX>>
  recipient_name : varchar(120)
  phone : varchar(40)
  address_line : varchar(255)
  city_or_region : varchar(120)
  postal_code : varchar(40)
  country : varchar(120)
  note : text
  status : varchar(20)
  created_at : datetime
  updated_at : datetime
  INDEX(user_id, status)
  INDEX(status, updated_at)
}

' ============================================================
' chatbot_db - PostgreSQL
' ============================================================
entity "chatbot_behaviorevent" as chatbot_behaviorevent {
  * id : bigint <<PK>>
  --
  user_ref : varchar(120) <<IDX>>
  event_type : varchar(40)
  category_slug : varchar(120)
  product_id : int
  metadata : json
  created_at : datetime
}

' ============================================================
' PHYSICAL FK RELATIONSHIPS INSIDE SERVICE DATABASES
' ERD uses crow-foot notation; labels note the equivalent VP class relationship.
' ============================================================
auth_user ||--o{ customer_legacyusermapping : user_id (composite cascade)
catalog_category ||--o{ catalog_product : category_id (shared protect)
orders_order ||--o{ orders_orderitem : order_id (composite cascade)
orders_order ||--o| orders_ordershipping : order_id (composite cascade)

' ============================================================
' LOGICAL IN-SERVICE EDITORIAL CONTENT CONTEXT
' These attach standalone content tables to the user_service domain.
' They are not physical DB constraints, FK columns, or auth_user.id references.
' ============================================================
auth_user |o..o{ customer_blogpost : editorial author text non-FK
auth_user |o..o{ customer_testimonial : testimonial content non-FK

' ============================================================
' LOGICAL CROSS-SERVICE ID / SNAPSHOT REFERENCES
' These are not physical DB constraints.
' ============================================================
auth_user ||..o{ orders_cartitem : user_id logical
auth_user ||..o{ orders_saveditem : user_id logical
auth_user ||..o{ orders_compareitem : user_id logical
auth_user ||..o{ orders_order : user_id logical

catalog_product ||..o{ orders_cartitem : product snapshot
catalog_product ||..o{ orders_saveditem : product snapshot
catalog_product ||..o{ orders_compareitem : product snapshot
catalog_product ||..o{ orders_orderitem : product snapshot

orders_order ||..o| payments_payment : order_id logical
orders_order ||..o| shipments_shipment : order_id logical
auth_user ||..o{ payments_payment : user_id logical
auth_user ||..o{ shipments_shipment : user_id logical

auth_user ||..o{ chatbot_behaviorevent : user_ref logical
catalog_category |o..o{ chatbot_behaviorevent : category_slug logical
catalog_product |o..o{ chatbot_behaviorevent : product_id logical

@enduml
